# Copy to .env

# MongoDB (Prisma)
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/DATABASE?retryWrites=true&w=majority"

# Telegram — required for `npm run bot` and for webhook mode
BOT_TOKEN=""

# false = long polling (use `npm run bot`). true = only POST /api/telegram/webhook
TELEGRAM_USE_WEBHOOK="false"

# Optional: first SUPER_ADMIN + default doctor (see lib/init.ts)
SUPER_ADMIN_USERNAME="super_admin"
SUPER_ADMIN_PASSWORD="super_admin123"
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_PHONE="+998900000000"

# Booking default price in UZS
FIXED_SERVICE_PRICE="50000"
